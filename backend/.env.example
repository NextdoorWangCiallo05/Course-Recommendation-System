# 生产环境密钥配置（请勿提交到版本控制）
# 使用以下命令生成新的密钥：
# python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# 数据库配置
# SQLite (开发环境默认)
# DATABASE_URL=sqlite:///course_recommendation.db

# MySQL (生产环境推荐)
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/course_recommendation

# Redis 缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
