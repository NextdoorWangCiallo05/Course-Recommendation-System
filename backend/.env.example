# ============================================
# 开发模式配置（SQLite + 无需 Docker）
# 使用方式：cp .env.example .env 并按需修改
# ============================================
# 密钥生成：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production

# 开发模式使用 SQLite（默认），注释掉即可
DATABASE_URL=sqlite:///course_recommendation.db

# 生产模式使用 MySQL（取消注释并修改）
# DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/course_recommendation

# Redis 缓存配置（无 Redis 时缓存自动降级为不启用）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
