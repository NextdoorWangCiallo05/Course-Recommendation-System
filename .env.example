# ============================================
# Docker 部署专用配置
# 使用方式：cp .env.example .env 并按需修改
# ============================================
# 密钥生成：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# MySQL 连接（Docker 服务名，与 docker-compose.yml 一致）
DATABASE_URL=mysql+pymysql://course_user:CoursePass2026!@mysql:3306/course_recommendation

# Redis 缓存（Docker 服务名）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MySQL 连接池
SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_RECYCLE=3600

# 缓存开关
CACHE_ENABLED=true
CACHE_DEFAULT_TIMEOUT=300
